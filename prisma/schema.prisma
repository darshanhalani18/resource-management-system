generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model activity_logs {
  id              Int           @id @default(autoincrement())
  organization_id Int
  user_id         Int
  entity_type     String?       @db.VarChar(50)
  entity_id       Int?
  action          String?       @db.VarChar(100)
  created_at      DateTime?     @default(now()) @db.DateTime(0)
  organizations   organizations @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_logs_org")
  users           users         @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_logs_user")

  @@index([organization_id], map: "fk_logs_org")
  @@index([user_id], map: "fk_logs_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model bookings {
  id                                Int              @id @default(autoincrement())
  resource_id                       Int
  user_id                           Int
  approved_by                       Int?
  start_datetime                    DateTime         @db.DateTime(0)
  end_datetime                      DateTime         @db.DateTime(0)
  purpose                           String?          @db.VarChar(255)
  status                            bookings_status? @default(PENDING)
  created_at                        DateTime?        @default(now()) @db.DateTime(0)
  users_bookings_approved_byTousers users?           @relation("bookings_approved_byTousers", fields: [approved_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_booking_approver")
  resources                         resources        @relation(fields: [resource_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_booking_resource")
  users_bookings_user_idTousers     users            @relation("bookings_user_idTousers", fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_booking_user")

  @@index([approved_by], map: "fk_booking_approver")
  @@index([resource_id], map: "fk_booking_resource")
  @@index([user_id], map: "fk_booking_user")
}

model locations {
  id                 Int           @id @default(autoincrement())
  organization_id    Int
  name               String        @db.VarChar(100)
  parent_location_id Int?
  created_at         DateTime?     @default(now()) @db.DateTime(0)
  organizations      organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_locations_org")
  locations          locations?    @relation("locationsTolocations", fields: [parent_location_id], references: [id], onUpdate: NoAction, map: "fk_locations_parent")
  other_locations    locations[]   @relation("locationsTolocations")
  resources          resources[]

  @@unique([organization_id, parent_location_id, name], map: "organization_id")
  @@index([parent_location_id], map: "fk_locations_parent")
}

model maintenance_records {
  id               Int                         @id @default(autoincrement())
  resource_id      Int
  reported_by      Int
  maintenance_type String?                     @db.VarChar(100)
  scheduled_date   DateTime                    @db.Date
  completed_date   DateTime?                   @db.Date
  status           maintenance_records_status? @default(SCHEDULED)
  notes            String?                     @db.Text
  created_at       DateTime?                   @default(now()) @db.DateTime(0)
  resources        resources                   @relation(fields: [resource_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_maintenance_resource")
  users            users                       @relation(fields: [reported_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_maintenance_user")

  @@index([resource_id], map: "fk_maintenance_resource")
  @@index([reported_by], map: "fk_maintenance_user")
}

model organizations {
  id                  Int                   @id @default(autoincrement())
  name                String                @db.VarChar(150)
  organization_code   String                @unique @db.VarChar(50)
  type                String                @db.VarChar(100)
  email               String                @unique(map: "email") @db.VarChar(150)
  phone               String?               @db.VarChar(15)
  country             String?               @db.VarChar(100)
  state               String?               @db.VarChar(100)
  city                String?               @db.VarChar(100)
  address             String?               @db.Text
  created_at          DateTime?             @default(now()) @db.DateTime(0)
  updated_at          DateTime?             @default(now()) @db.DateTime(0)
  activity_logs       activity_logs[]
  locations           locations[]
  resource_categories resource_categories[]
  resources           resources[]
  users               users[]
}

model resource_categories {
  id              Int           @id @default(autoincrement())
  organization_id Int
  name            String        @db.VarChar(100)
  description     String?       @db.Text
  created_at      DateTime?     @default(now()) @db.DateTime(0)
  organizations   organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_category_org")
  resources       resources[]

  @@unique([organization_id, name], map: "organization_id")
}

model resource_features {
  id          Int       @id @default(autoincrement())
  resource_id Int
  name        String    @db.VarChar(100)
  value       String?   @db.VarChar(255)
  created_at  DateTime? @default(now()) @db.DateTime(0)
  resources   resources @relation(fields: [resource_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_feature_resource")

  @@index([resource_id], map: "fk_feature_resource")
}

model resources {
  id                  Int                   @id @default(autoincrement())
  organization_id     Int
  category_id         Int
  location_id         Int?
  name                String                @db.VarChar(150)
  code                String?               @db.VarChar(50)
  capacity            Int?
  status              resources_status?     @default(AVAILABLE)
  description         String?               @db.Text
  created_at          DateTime?             @default(now()) @db.DateTime(0)
  updated_at          DateTime?             @default(now()) @db.DateTime(0)
  bookings            bookings[]
  maintenance_records maintenance_records[]
  resource_features   resource_features[]
  resource_categories resource_categories   @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_resource_category")
  locations           locations?            @relation(fields: [location_id], references: [id], onUpdate: NoAction, map: "fk_resource_location")
  organizations       organizations         @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_resource_org")

  @@index([category_id], map: "fk_resource_category")
  @@index([location_id], map: "fk_resource_location")
  @@index([organization_id], map: "fk_resource_org")
}

model roles {
  id         Int       @id @default(autoincrement())
  name       String    @unique(map: "name") @db.VarChar(50)
  created_at DateTime? @default(now()) @db.DateTime(0)
  users      users[]
}

model users {
  id                                   Int                   @id @default(autoincrement())
  organization_id                      Int
  role_id                              Int
  name                                 String                @db.VarChar(100)
  email                                String                @unique(map: "email") @db.VarChar(150)
  password_hash                        String                @db.VarChar(255)
  status                               users_status?         @default(ACTIVE)
  created_at                           DateTime?             @default(now()) @db.DateTime(0)
  updated_at                           DateTime?             @default(now()) @db.DateTime(0)
  activity_logs                        activity_logs[]
  bookings_bookings_approved_byTousers bookings[]            @relation("bookings_approved_byTousers")
  bookings_bookings_user_idTousers     bookings[]            @relation("bookings_user_idTousers")
  maintenance_records                  maintenance_records[]
  organizations                        organizations         @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_users_org")
  roles                                roles                 @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_users_role")

  @@index([organization_id], map: "fk_users_org")
  @@index([role_id], map: "fk_users_role")
}

enum maintenance_records_status {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum users_status {
  ACTIVE
  INACTIVE
}

enum bookings_status {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum resources_status {
  AVAILABLE
  BOOKED
  MAINTENANCE
  RETIRED
}
