generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model activity_logs {
  id              Int           @id @default(autoincrement())
  organization_id Int
  user_id         Int
  entity_type     String?       @db.VarChar(50)
  entity_id       Int?
  action          String?       @db.VarChar(100)
  created_at      DateTime      @default(now())
  organizations   organizations @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users           users         @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([organization_id])
  @@index([user_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model bookings {
  id                                Int              @id @default(autoincrement())
  resource_id                       Int
  user_id                           Int
  approved_by                       Int?
  start_datetime                    DateTime
  end_datetime                      DateTime
  purpose                           String?          @db.VarChar(255)
  status                            bookings_status? @default(PENDING)
  created_at                        DateTime         @default(now())
  users_bookings_approved_byTousers users?           @relation("bookings_approved_byTousers", fields: [approved_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  resources                         resources        @relation(fields: [resource_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_bookings_user_idTousers     users            @relation("bookings_user_idTousers", fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([approved_by])
  @@index([resource_id])
  @@index([user_id])
}

model locations {
  id                 Int           @id @default(autoincrement())
  organization_id    Int
  name               String        @db.VarChar(100)
  parent_location_id Int?
  created_at         DateTime      @default(now())
  organizations      organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  locations          locations?    @relation("locationsTolocations", fields: [parent_location_id], references: [id], onUpdate: NoAction)
  other_locations    locations[]   @relation("locationsTolocations")
  resources          resources[]

  @@unique([organization_id, parent_location_id, name])
  @@index([parent_location_id])
}

model maintenance_records {
  id               Int                         @id @default(autoincrement())
  resource_id      Int
  reported_by      Int
  maintenance_type String?                     @db.VarChar(100)
  scheduled_date   DateTime                    @db.Date
  completed_date   DateTime?                   @db.Date
  status           maintenance_records_status? @default(SCHEDULED)
  notes            String?                     @db.Text
  created_at       DateTime                    @default(now())
  resources        resources                   @relation(fields: [resource_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users            users                       @relation(fields: [reported_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([resource_id])
  @@index([reported_by])
}

model organizations {
  id                  Int                   @id @default(autoincrement())
  name                String                @db.VarChar(150)
  organization_code   String                @unique @db.VarChar(50)
  type                String                @db.VarChar(100)
  email               String                @unique @db.VarChar(150)
  phone               String?               @db.VarChar(15)
  country             String?               @db.VarChar(100)
  state               String?               @db.VarChar(100)
  city                String?               @db.VarChar(100)
  address             String?               @db.Text
  created_at          DateTime              @default(now())
  updated_at          DateTime              @default(now())
  activity_logs       activity_logs[]
  locations           locations[]
  resource_categories resource_categories[]
  resources           resources[]
  users               users[]
}

model resource_categories {
  id              Int           @id @default(autoincrement())
  organization_id Int
  name            String        @db.VarChar(100)
  description     String?       @db.Text
  created_at      DateTime      @default(now())
  organizations   organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  resources       resources[]

  @@unique([organization_id, name])
}

model resource_features {
  id          Int       @id @default(autoincrement())
  resource_id Int
  name        String    @db.VarChar(100)
  value       String?   @db.VarChar(255)
  created_at  DateTime  @default(now())
  resources   resources @relation(fields: [resource_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([resource_id])
}

model resources {
  id                  Int                   @id @default(autoincrement())
  organization_id     Int
  category_id         Int
  location_id         Int?
  name                String                @db.VarChar(150)
  code                String?               @db.VarChar(50)
  capacity            Int?
  status              resources_status?     @default(AVAILABLE)
  description         String?               @db.Text
  created_at          DateTime              @default(now())
  updated_at          DateTime              @default(now())
  bookings            bookings[]
  maintenance_records maintenance_records[]
  resource_features   resource_features[]
  resource_categories resource_categories   @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  locations           locations?            @relation(fields: [location_id], references: [id], onUpdate: NoAction)
  organizations       organizations         @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([category_id])
  @@index([location_id])
  @@index([organization_id])
}

model roles {
  id         Int      @id @default(autoincrement())
  name       String   @unique @db.VarChar(50)
  created_at DateTime @default(now())
  users      users[]
}

model users {
  id                                   Int                   @id @default(autoincrement())
  organization_id                      Int
  role_id                              Int
  name                                 String                @db.VarChar(100)
  email                                String                @unique @db.VarChar(150)
  password_hash                        String                @db.VarChar(255)
  status                               users_status?         @default(PENDING)
  temp_password                        String?               @db.VarChar(255)
  must_change_password                 Boolean               @default(true)
  created_at                           DateTime              @default(now())
  updated_at                           DateTime              @default(now())
  activity_logs                        activity_logs[]
  bookings_bookings_approved_byTousers bookings[]            @relation("bookings_approved_byTousers")
  bookings_bookings_user_idTousers     bookings[]            @relation("bookings_user_idTousers")
  maintenance_records                  maintenance_records[]
  organizations                        organizations         @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  roles                                roles                 @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([organization_id])
  @@index([role_id])
}

enum maintenance_records_status {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum users_status {
  ACTIVE
  INACTIVE
  PENDING
}

enum bookings_status {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum resources_status {
  AVAILABLE
  BOOKED
  MAINTENANCE
  RETIRED
}
